{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "inline": "esbuild src/inline/*.js --minify --outdir=public/dist/inline",
    "dev": "rm -rf public/dist && mprocs",
    "build": "unocss && vite build && pnpm run inline",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:types": "tsc --noEmit",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,yml}\" --check",
    "blocks:extract": "node scripts/content-extractor/extract.ts",
    "blocks:inject": "node scripts/content-extractor/inject.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/tabler": "^1.2.35",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.9.3",
    "@unocss/cli": "^66.7.0",
    "@unocss/core": "^66.7.0",
    "@unocss/eslint-plugin": "^66.7.0",
    "@unocss/preset-wind4": "^66.7.0",
    "@unocss/reset": "^66.7.0",
    "alpinejs": "^3.15.12",
    "consola": "^3.4.2",
    "culori": "^4.0.2",
    "drauu": "^1.0.0",
    "embla-carousel": "^9.0.0-rc02",
    "es-toolkit": "^1.47.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "mprocs": "^0.9.6",
    "postcss": "^8.5.15",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "unlazy": "^2.0.1",
    "unocss": "^66.7.0",
    "vite": "^8.0.16",
    "vite-plugin-full-reload": "^1.2.0"
  }
}
